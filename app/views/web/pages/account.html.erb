<% format_date = ->(value) { value&.strftime("%b %-d, %Y") || "n/a" } %>
<% format_timestamp = ->(value) { value&.strftime("%b %-d, %Y %H:%M") || "n/a" } %>
<% entitlement = current_entitlement %>
<% subscription = @latest_subscription %>
<% billing_customer = current_user.billing_customer %>
<% subscribed = subscription.present? %>
<% subscription_trial = subscribed && subscription.status == "trialing" %>
<% subscription_cancel_scheduled = subscribed && subscription.cancel_at_period_end? %>
<% account_trial = entitlement&.access_granted? && entitlement.source == "account_trial" %>
<% access_active = entitlement&.access_granted? %>
<% access_end_at = subscription&.current_period_end_at || entitlement&.active_until %>
<% desktop_checkout_handoff = @desktop_checkout_handoff_url.present? %>
<% access_status_label = if subscribed
  if subscription_cancel_scheduled
    "Cancellation scheduled"
  elsif subscription_trial
    "Pro subscribed"
  elsif subscription.grants_access?
    "Pro active"
  else
    "Subscription inactive"
  end
elsif account_trial
  "Trial active"
elsif access_active
  "Access active"
else
  "Access inactive"
end %>
<% access_status_class = if subscribed && subscription.grants_access?
  subscription_cancel_scheduled ? "status status--ending" : "status status--active"
elsif account_trial
  "status status--trialing"
elsif access_active
  "status status--active"
else
  "status status--inactive"
end %>
<% summary_title = if subscription_cancel_scheduled
  "Your Pro plan stays active until #{format_date.call(subscription.current_period_end_at)}."
elsif subscription_trial
  "You're subscribed to Pro."
elsif subscribed && subscription.grants_access?
  "Your Pro access is active."
elsif account_trial
  "You're on the included 7-day trial."
else
  "Your account is ready for Pro."
end %>
<% summary_copy = if subscription_cancel_scheduled
  "Auto-renew is off, but billing access remains on until the current period ends. Open Manage subscription to change it in Stripe."
elsif subscription_trial
  "Stripe already has a subscription for this account. Open Manage subscription for payment details, invoices, or cancellation."
elsif subscribed && subscription.grants_access?
  "Billing, desktop access, and account identity are already linked. Manage payment details or cancellation from this page."
elsif account_trial
  "You have website and desktop access right now, but there is no paid subscription attached yet."
else
  "Start a subscription to unlock billing management, self-serve cancellation, and continuous Pro access."
end %>
<% renewal_label = if subscription_trial || account_trial
  "Trial ends"
elsif subscription_cancel_scheduled
  "Access ends"
elsif subscribed
  "Renews"
else
  "Access until"
end %>
<% renewal_value = if subscription_trial
  format_date.call(subscription.current_period_end_at)
elsif account_trial
  format_date.call(entitlement&.trial_ends_at)
elsif subscribed
  format_date.call(subscription.current_period_end_at)
else
  format_date.call(access_end_at)
end %>
<% purchase_state_value = if subscribed
  subscription_cancel_scheduled ? "Subscribed, ends #{format_date.call(subscription.current_period_end_at)}" : "Subscribed (#{subscription.status.humanize})"
elsif account_trial
  "Not subscribed yet"
else
  "No subscription"
end %>
<% billing_note = if subscription_cancel_scheduled
  "Auto-renew is off. You keep Pro access until #{format_date.call(subscription.current_period_end_at)}. Use Manage subscription if you want to change it in Stripe."
elsif subscription_trial
  "Your payment method and subscription are already attached to this account. Use Manage subscription for invoices, payment details, or cancellation."
elsif subscribed
  "Use Manage subscription for invoices, payment details, or cancellation."
elsif account_trial
  "This is the built-in account trial. Starting a subscription replaces trial-only access with a managed Stripe plan."
else
  "No active Stripe subscription is attached yet."
end %>

<section class="hero hero--account">
  <div class="hero__layout hero__layout--account">
    <div class="hero__content">
      <span class="hero__eyebrow">Account Center</span>
      <h1 class="hero__title hero__title--account">Your Voxlane account.</h1>
      <p class="hero__copy">
        Keep your login methods, subscription, desktop installs, and support details tied to one Voxlane identity.
      </p>

      <div class="button-row">
        <% if billing_customer.present? %>
          <%= button_to "Manage subscription",
            billing_portal_path(return_url: account_url),
            method: :post,
            class: "button button--primary" %>
        <% else %>
          <%= button_to "Start Pro subscription",
            checkout_path(
              success_url: account_url(checkout: "success"),
              cancel_url: pricing_url(checkout: "cancelled")
            ),
            method: :post,
            class: "button button--primary" %>
        <% end %>
        <% if desktop_checkout_handoff %>
          <a class="button button--secondary" href="<%= @desktop_checkout_handoff_url %>">Open Voxlane</a>
        <% end %>
        <a class="button button--secondary" href="<%= download_path %>">Download macOS app</a>
        <a class="button button--secondary" href="<%= support_path %>">Get support</a>
      </div>
    </div>

    <aside class="account-summary">
      <span class="<%= access_status_class %>"><%= access_status_label %></span>
      <h2 class="account-summary__title"><%= summary_title %></h2>
      <p class="account-summary__copy"><%= summary_copy %></p>

      <div class="account-summary__stats">
        <div class="account-summary__stat">
          <span class="account-summary__label">Plan</span>
          <span class="account-summary__value"><%= subscribed ? "Voxlane Pro" : (access_active ? "7-day trial" : "No active plan") %></span>
        </div>
        <div class="account-summary__stat">
          <span class="account-summary__label">Purchase state</span>
          <span class="account-summary__value"><%= purchase_state_value %></span>
        </div>
        <div class="account-summary__stat">
          <span class="account-summary__label"><%= renewal_label %></span>
          <span class="account-summary__value"><%= renewal_value %></span>
        </div>
      </div>
    </aside>
  </div>
</section>

<% if desktop_checkout_handoff %>
  <script>
    window.addEventListener("load", function () {
      window.setTimeout(function () {
        window.location.href = "<%= @desktop_checkout_handoff_url %>";
      }, 700);
    });
  </script>
<% end %>

<section class="section-card">
  <div class="section-heading-row">
    <div class="section-heading-copy">
      <span class="kicker">Billing & Access</span>
      <h2>Subscription, renewal, and cancellation</h2>
      <p class="meta">Show paid status clearly, manage Stripe billing, and keep app access in sync.</p>
    </div>
    <span class="<%= access_status_class %>"><%= access_status_label %></span>
  </div>

  <div class="meta-grid account-meta-grid">
    <div class="meta-card">
      <span class="meta-card__label">Plan</span>
      <span class="meta-card__value"><%= subscribed ? "Voxlane Pro" : (access_active ? "7-day trial" : "No active plan") %></span>
    </div>
    <div class="meta-card">
      <span class="meta-card__label">Purchase state</span>
      <span class="meta-card__value"><%= purchase_state_value %></span>
    </div>
    <div class="meta-card">
      <span class="meta-card__label">Billing state</span>
      <span class="meta-card__value"><%= subscribed ? subscription.status.humanize : "None" %></span>
    </div>
    <div class="meta-card">
      <span class="meta-card__label"><%= renewal_label %></span>
      <span class="meta-card__value"><%= renewal_value %></span>
    </div>
  </div>

  <div class="button-row section-actions">
    <% if billing_customer.present? %>
      <%= button_to "Manage subscription",
        billing_portal_path(return_url: account_url),
        method: :post,
        class: "button button--primary" %>
    <% end %>

    <% unless subscribed %>
      <%= button_to "Start Pro subscription",
        checkout_path(
          success_url: account_url(checkout: "success"),
          cancel_url: pricing_url(checkout: "cancelled")
        ),
        method: :post,
        class: "button button--secondary" %>
    <% end %>
  </div>

  <p class="meta account-note"><%= billing_note %></p>

  <div class="grid grid--2">
    <div class="grid-card">
      <h3>Website billing</h3>
      <p class="lede">
        Checkout, payment method updates, and invoice history stay on the web through Stripe-hosted pages.
      </p>
    </div>
    <div class="grid-card">
      <h3>Desktop access</h3>
      <p class="lede">
        The macOS app reads the same server-side entitlement. If access looks stale, reopen Voxlane or refresh access in the app.
      </p>
    </div>
  </div>
</section>

<section class="section-card">
  <div class="section-heading-row">
    <div class="section-heading-copy">
      <span class="kicker">Profile</span>
      <h2>Identity and account details</h2>
      <p class="meta">Your website account, billing identity, and desktop login all stay tied to the same profile.</p>
    </div>
  </div>

  <div class="split">
    <div class="section-card section-card--subtle stack">
      <%= form_with url: account_profile_path, scope: :profile, method: :patch, html: { class: "stack-form" } do |form| %>
        <div class="field">
          <%= form.label :display_name, "Display name" %>
          <%= form.text_field :display_name, value: current_user.display_name, placeholder: "Your name" %>
        </div>
        <div class="field">
          <label>Email</label>
          <input type="email" value="<%= current_user.email %>" disabled>
        </div>
        <p class="meta">Use this profile across the website, billing flows, and the Voxlane macOS app.</p>
        <div class="button-row">
          <%= form.submit "Save profile", class: "button button--primary" %>
        </div>
      <% end %>
    </div>

    <div class="section-card section-card--subtle stack">
      <div class="meta-grid account-meta-grid">
        <div class="meta-card">
          <span class="meta-card__label">Email</span>
          <span class="meta-card__value"><%= current_user.email %></span>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Access source</span>
          <span class="meta-card__value"><%= subscribed ? "Stripe subscription" : (account_trial ? "Included trial" : "None") %></span>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Member since</span>
          <span class="meta-card__value"><%= format_date.call(current_user.created_at) %></span>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Last seen</span>
          <span class="meta-card__value"><%= format_timestamp.call(current_user.last_seen_at) %></span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-card">
  <div class="section-heading-row">
    <div class="section-heading-copy">
      <span class="kicker">Security</span>
      <h2><%= password_settings_visible? ? "Sign-in methods and password" : "Sign-in methods" %></h2>
      <p class="meta">
        <% if password_settings_visible? %>
          Add a password, keep email login current, and link social providers when available.
        <% else %>
          Manage the sign-in providers connected to this account.
        <% end %>
      </p>
    </div>
  </div>

  <div class="split<%= " split--single" unless password_settings_visible? %>">
    <% if password_settings_visible? %>
      <div class="section-card section-card--subtle stack">
        <h3>Password</h3>
        <p class="lede">
          <% if current_user.password_login_enabled? %>
            Update your password for email sign-in.
          <% else %>
            You do not have email login enabled yet. Set a password if you also want to sign in by email.
          <% end %>
        </p>

        <%= form_with url: account_password_path, scope: :password, method: :patch, html: { class: "stack-form" } do |form| %>
          <%= label_tag "password_email", "Email address", class: "sr-only" %>
          <%= email_field_tag "password[email]", current_user.email, class: "sr-only", autocomplete: "username", tabindex: -1, id: "password_email" %>
          <% if current_user.password_login_enabled? %>
            <div class="field">
              <%= form.label :current_password, "Current password" %>
              <%= form.password_field :current_password, autocomplete: "current-password" %>
            </div>
          <% end %>
          <div class="field">
            <%= form.label :password, current_user.password_login_enabled? ? "New password" : "Set password" %>
            <%= form.password_field :password, autocomplete: "new-password" %>
          </div>
          <div class="field">
            <%= form.label :password_confirmation, "Confirm password" %>
            <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
          </div>
          <div class="button-row">
            <%= form.submit current_user.password_login_enabled? ? "Update password" : "Enable email login", class: "button button--primary" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="section-card section-card--subtle stack">
      <h3>Connected sign-in methods</h3>
      <div class="grid grid--3">
        <div class="meta-card">
          <span class="meta-card__label">Email login</span>
          <span class="meta-card__value"><%= current_user.password_login_enabled? ? "Enabled" : "Not configured" %></span>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Google</span>
          <span class="meta-card__value"><%= current_user.google_connected? ? "Connected" : "Not connected" %></span>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Apple</span>
          <span class="meta-card__value"><%= current_user.apple_connected? ? "Connected" : "Not connected" %></span>
        </div>
      </div>

      <% if (google_oauth_enabled? && !current_user.google_connected?) || (apple_oauth_enabled? && !current_user.apple_connected?) %>
        <div class="button-row section-actions">
          <% if google_oauth_enabled? && !current_user.google_connected? %>
            <a class="button button--secondary" href="<%= google_auth_path %>">Connect with Google</a>
          <% end %>
          <% if apple_oauth_enabled? && !current_user.apple_connected? %>
            <a class="button button--secondary" href="<%= apple_auth_path %>">Connect with Apple</a>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="section-card">
  <div class="section-heading-row">
    <div class="section-heading-copy">
      <span class="kicker">Devices</span>
      <h2>Recently seen app installations</h2>
      <p class="meta">Desktop installs appear here automatically after sign-in from the macOS app.</p>
    </div>
  </div>

  <% if @devices.any? %>
    <div class="meta-grid account-meta-grid">
      <% @devices.each do |device| %>
        <div class="meta-card">
          <span class="meta-card__label"><%= device.platform.presence || "Unknown platform" %></span>
          <span class="meta-card__value"><%= device.app_version.presence || "Unknown version" %></span>
          <p class="meta">ID: <%= device.device_identifier %></p>
          <p class="meta">Last seen: <%= format_timestamp.call(device.last_seen_at) %></p>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="meta">No devices have checked in yet. Sign in from the macOS app and the current build will appear here automatically.</p>
  <% end %>
</section>

<section class="section-card">
  <div class="section-heading-row">
    <div class="section-heading-copy">
      <span class="kicker">Support & Legal</span>
      <h2>Help, policies, and release details</h2>
      <p class="meta">Support, legal references, and release notes stay a click away from the account dashboard.</p>
    </div>
  </div>

  <div class="grid grid--2">
    <div class="grid-card">
      <h3>Support</h3>
      <p class="lede">Need help with login, billing, or access? Reach out and include the email tied to your Voxlane account.</p>
      <div class="button-row section-actions">
        <a class="button button--secondary" href="<%= support_path %>">Open support</a>
        <a class="button button--ghost" href="mailto:<%= AppConfig.support_email %>"><%= AppConfig.support_email %></a>
      </div>
    </div>
    <div class="grid-card">
      <h3>Legal</h3>
      <p class="lede">Review how Voxlane handles billing, direct downloads, and account-based access.</p>
      <div class="button-row section-actions">
        <a class="button button--secondary" href="<%= privacy_path %>">Privacy</a>
        <a class="button button--secondary" href="<%= terms_path %>">Terms</a>
        <a class="button button--secondary" href="<%= release_notes_path %>">Release notes</a>
      </div>
    </div>
  </div>
</section>
