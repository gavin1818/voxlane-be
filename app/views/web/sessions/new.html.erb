<section class="auth-shell">
  <div class="auth-panel">
    <div class="auth-panel__mark" aria-hidden="true">
      <span></span>
    </div>

    <h1 class="auth-panel__title">Welcome to Voxlane</h1>
    <p class="auth-panel__copy">
      <% if params[:desktop_login].present? %>
        Sign in to finish connecting the Voxlane Mac app.
      <% else %>
        Voice keyboard that signs in through your Voxlane account.
      <% end %>
    </p>

    <div class="auth-panel__actions">
      <% if google_oauth_enabled? %>
        <a class="auth-option auth-option--dark" href="<%= google_auth_path(desktop_login: params[:desktop_login]) %>">
          <span class="auth-option__icon auth-option__icon--google">G</span>
          <span>Continue with Google</span>
        </a>
      <% else %>
        <span class="auth-option auth-option--dark auth-option--disabled">
          <span class="auth-option__icon auth-option__icon--google">G</span>
          <span>Continue with Google</span>
        </span>
      <% end %>

      <a class="auth-option" href="<%= login_email_path(desktop_login: params[:desktop_login]) %>">
        <span class="auth-option__icon"><svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true"><rect x="2" y="4" width="14" height="10" rx="3" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4.5 6.5L9 10l4.5-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <span>Continue with email</span>
      </a>

      <% if apple_oauth_enabled? %>
        <a class="auth-option" href="<%= apple_auth_path(desktop_login: params[:desktop_login]) %>">
          <span class="auth-option__icon"><svg width="16" height="18" viewBox="0 0 16 18" aria-hidden="true"><path d="M11.2 2.5c.7-.9 1.1-2 1-2.5-.9.1-2 .7-2.7 1.5-.6.7-1.1 1.8-1 2.8 1 .1 2-.5 2.7-1.8ZM13.7 9.2c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.9-1.8-3.5-1.8-1.5-.2-2.8.9-3.6.9-.8 0-1.9-.9-3.1-.9-1.6 0-3 .9-3.8 2.3-1.7 2.9-.4 7.3 1.2 9.6.8 1.1 1.7 2.4 2.9 2.3 1.1 0 1.6-.8 3-.8s1.8.8 3 .8c1.2 0 2-.9 2.8-2 .9-1.3 1.3-2.7 1.3-2.8-.1 0-2.2-.8-2.2-4.1Z" fill="currentColor"/></svg></span>
          <span>Continue with Apple</span>
        </a>
      <% else %>
        <span class="auth-option auth-option--disabled">
          <span class="auth-option__icon"><svg width="16" height="18" viewBox="0 0 16 18" aria-hidden="true"><path d="M11.2 2.5c.7-.9 1.1-2 1-2.5-.9.1-2 .7-2.7 1.5-.6.7-1.1 1.8-1 2.8 1 .1 2-.5 2.7-1.8ZM13.7 9.2c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.9-1.8-3.5-1.8-1.5-.2-2.8.9-3.6.9-.8 0-1.9-.9-3.1-.9-1.6 0-3 .9-3.8 2.3-1.7 2.9-.4 7.3 1.2 9.6.8 1.1 1.7 2.4 2.9 2.3 1.1 0 1.6-.8 3-.8s1.8.8 3 .8c1.2 0 2-.9 2.8-2 .9-1.3 1.3-2.7 1.3-2.8-.1 0-2.2-.8-2.2-4.1Z" fill="currentColor"/></svg></span>
          <span>Continue with Apple</span>
        </span>
      <% end %>
    </div>

    <p class="auth-panel__legal">
      By signing in, you agree to the <a href="<%= terms_path %>">Terms of Service</a> and <a href="<%= privacy_path %>">Privacy Policy</a>.
    </p>
  </div>
</section>
