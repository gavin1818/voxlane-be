<section class="auth-shell auth-shell--form">
  <div class="auth-panel auth-panel--form">
    <div class="auth-panel__nav">
      <a class="auth-back" href="<%= login_path(desktop_login: params[:desktop_login]) %>">
        <span aria-hidden="true">←</span>
        <span>Back</span>
      </a>
    </div>

    <div class="auth-panel__mark" aria-hidden="true">
      <span></span>
    </div>

    <% if @password_step %>
      <h1 class="auth-panel__title auth-panel__title--form">Enter your password</h1>
      <p class="auth-panel__copy auth-panel__copy--wide">
        Continue as <span class="auth-panel__email"><%= @prefilled_email %></span>.
      </p>

      <%= form_with url: login_path, scope: :auth, method: :post, html: { class: "auth-form" } do |form| %>
        <%= hidden_field_tag :desktop_login, params[:desktop_login] if params[:desktop_login].present? %>
        <%= form.label :email, "Email address", class: "sr-only" %>
        <%= form.email_field :email, value: @prefilled_email, autocomplete: "username", class: "sr-only", tabindex: -1 %>

        <div class="auth-field">
          <%= form.label :password, "Password", class: "sr-only" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Password" %>
        </div>

        <%= form.submit "Continue", class: "auth-submit auth-submit--primary" %>
      <% end %>

      <p class="auth-panel__subcopy">
        <a href="<%= forgot_password_path(desktop_login: params[:desktop_login]) %>">Forgot password?</a>
        <span>•</span>
        <a href="<%= login_email_path(desktop_login: params[:desktop_login]) %>">Use a different email</a>
      </p>
    <% else %>
      <h1 class="auth-panel__title auth-panel__title--form">Sign in with email</h1>
      <p class="auth-panel__copy auth-panel__copy--wide">
        Enter your email to continue on the web and unlock <%= AppConfig.app_name %> on this Mac.
      </p>

      <%= form_with url: login_email_path, scope: :auth, method: :post, html: { class: "auth-form" } do |form| %>
        <%= hidden_field_tag :desktop_login, params[:desktop_login] if params[:desktop_login].present? %>

        <div class="auth-field">
          <%= form.label :email, "Email address", class: "sr-only" %>
          <%= form.email_field :email, required: true, autocomplete: "email", placeholder: "Email address", value: @prefilled_email %>
        </div>

        <%= form.submit "Continue with email", class: "auth-submit auth-submit--primary" %>
      <% end %>

      <p class="auth-panel__subcopy">
        New to <%= AppConfig.app_name %>?
        <a href="<%= signup_path(email: @prefilled_email, desktop_login: params[:desktop_login]) %>">Create account</a>
      </p>
    <% end %>

    <p class="auth-panel__legal">
      By signing in, you agree to the <a href="<%= terms_path %>">Terms of Service</a> and <a href="<%= privacy_path %>">Privacy Policy</a>.
    </p>
  </div>
</section>
