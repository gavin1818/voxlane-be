<section class="hero">
  <span class="hero__eyebrow">Choose a New Password</span>
  <h1 class="hero__title">Set a fresh password for your Voxlane account.</h1>
  <p class="hero__copy">
    After you save it, the website and macOS app will use the updated credentials.
  </p>
</section>

<section class="section-card stack" style="max-width: 620px; margin: 0 auto;">
  <%= form_with url: reset_password_path(@raw_token), scope: :password, method: :patch do |form| %>
    <div class="field">
      <%= form.label :password, "New password" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password" %>
    </div>
    <div class="field" style="margin-top: 14px;">
      <%= form.label :password_confirmation, "Confirm new password" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
    </div>
    <div class="button-row" style="margin-top: 16px;">
      <%= form.submit "Save new password", class: "button button--primary" %>
    </div>
  <% end %>
</section>
