<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= AppConfig.app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= render "shared/google_analytics" %>
    <style>
      :root {
        --bg: #eef4f1;
        --bg-accent: #d6ede7;
        --surface: rgba(255, 255, 255, 0.8);
        --surface-strong: rgba(255, 255, 255, 0.94);
        --surface-dark: #043b36;
        --surface-dark-strong: #072f2b;
        --ink: #082724;
        --muted: #5a6d68;
        --line: rgba(8, 39, 36, 0.1);
        --line-strong: rgba(8, 39, 36, 0.16);
        --primary: #1da99b;
        --primary-strong: #0c8c80;
        --primary-soft: rgba(29, 169, 155, 0.12);
        --accent: #d7f1eb;
        --success: #167454;
        --warning: #94591d;
        --shadow: 0 26px 70px rgba(4, 59, 54, 0.12);
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 20px;
        --radius-sm: 14px;
        --font-display: "Avenir Next", "Trebuchet MS", "Gill Sans", sans-serif;
        --font-sans: "Avenir Next", "Segoe UI", sans-serif;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.96), transparent 30%),
          radial-gradient(circle at 88% 8%, rgba(29, 169, 155, 0.14), transparent 22%),
          linear-gradient(180deg, #f8fbfa 0%, var(--bg) 42%, #e5f1ed 100%);
      }

      a { color: inherit; text-decoration: none; }

      .shell {
        width: min(1180px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 20px 0 72px;
      }

      .shell__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 22px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(16px);
        box-shadow: var(--shadow);
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .brand__name {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .brand__tag {
        color: var(--muted);
        font-size: 0.85rem;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav__links {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
      }

      .nav__link {
        color: var(--muted);
        padding: 10px 14px;
        border-radius: 999px;
        transition: background 140ms ease, color 140ms ease;
      }

      .nav__link:hover {
        background: rgba(255, 255, 255, 0.82);
        color: var(--ink);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid var(--line);
        font-size: 0.9rem;
        color: var(--muted);
      }

      .pill--dark {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.16);
        color: rgba(244, 250, 248, 0.92);
      }

      .flash-stack {
        display: grid;
        gap: 12px;
        margin: 18px 0 0;
      }

      .flash {
        padding: 14px 16px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--line);
        background: var(--surface-strong);
      }

      .flash--notice { border-color: rgba(25, 115, 71, 0.18); color: var(--success); }
      .flash--alert { border-color: rgba(156, 90, 0, 0.18); color: var(--warning); }

      .hero,
      .section-card,
      .grid-card,
      .feature-band,
      .plan-card,
      .workflow-card,
      .feature-card,
      .mini-stat,
      .showcase-card,
      .signal-card {
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      main {
        display: grid;
        gap: 22px;
        margin-top: 22px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        padding: clamp(28px, 4vw, 42px);
        display: grid;
        gap: 22px;
      }

      .hero--landing {
        background:
          radial-gradient(circle at top right, rgba(29, 169, 155, 0.14), transparent 26%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(243, 250, 248, 0.9));
      }

      .hero__layout {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
        gap: 28px;
        align-items: center;
      }

      .hero__content,
      .hero__media {
        position: relative;
        z-index: 1;
      }

      .hero__eyebrow {
        display: inline-flex;
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary);
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      .hero__title {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(2.8rem, 6vw, 5rem);
        line-height: 0.92;
        letter-spacing: -0.05em;
        max-width: 14ch;
      }

      .hero--landing .hero__title {
        max-width: 9.5ch;
        font-size: clamp(3.4rem, 7vw, 6rem);
      }

      .hero__copy,
      .lede,
      .meta,
      .stack > p,
      .section-heading > p,
      .plan-card p,
      .feature-card p,
      .workflow-card p,
      .showcase-card p,
      .signal-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
      }

      .hero__copy {
        max-width: 60ch;
        font-size: 1.05rem;
      }

      .hero__caption {
        margin: 0;
        max-width: 56ch;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.6;
      }

      .button-row,
      .stats,
      .grid,
      .badge-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .button,
      .button_to button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 0 20px;
        border-radius: 999px;
        border: 1px solid transparent;
        font: inherit;
        font-weight: 600;
        cursor: pointer;
        transition: transform 120ms ease, background 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
      }

      .button:hover,
      .button_to button:hover {
        transform: translateY(-1px);
      }

      .button--primary,
      .button_to .button--primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-strong) 100%);
        color: white;
        box-shadow: 0 16px 34px rgba(13, 140, 128, 0.24);
      }

      .button--secondary,
      .button_to .button--secondary {
        background: rgba(255, 255, 255, 0.88);
        border-color: var(--line-strong);
        color: var(--ink);
      }

      .button_to { margin: 0; }

      .grid {
        margin-top: 20px;
        align-items: stretch;
      }

      .grid-card {
        flex: 1 1 280px;
        padding: 22px;
      }

      .cards-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .cards-grid--two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .grid-card h2,
      .grid-card h3,
      .section-card h2,
      .section-card h3,
      .feature-card h3,
      .workflow-card h3,
      .signal-card h3,
      .mini-stat h3,
      .plan-card h3,
      .showcase-card h3 {
        margin: 0 0 12px;
      }

      .grid-card ul,
      .section-card ul,
      .plan-card ul,
      .feature-band ul {
        margin: 0;
        padding-left: 18px;
        color: var(--muted);
        line-height: 1.7;
      }

      .section-card {
        padding: clamp(24px, 3vw, 34px);
      }

      .split {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
        gap: 18px;
      }

      .split--single {
        grid-template-columns: minmax(0, 1fr);
      }

      .field {
        display: grid;
        gap: 8px;
      }

      .field label {
        font-weight: 600;
      }

      .field input {
        width: 100%;
        min-height: 48px;
        padding: 0 16px;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.92);
        font: inherit;
      }

      .kicker {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--primary);
        font-weight: 700;
      }

      .kicker--light {
        color: rgba(191, 239, 231, 0.88);
      }

      .section-heading {
        display: grid;
        gap: 10px;
        margin-bottom: 22px;
      }

      .section-heading h2 {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(2rem, 4vw, 3.2rem);
        line-height: 0.96;
        letter-spacing: -0.05em;
        max-width: 12ch;
      }

      .section-heading--wide h2 {
        max-width: 16ch;
      }

      .section-heading--light h2,
      .section-heading--light p {
        color: white;
      }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 700;
      }

      .status--active { background: rgba(25, 115, 71, 0.12); color: var(--success); }
      .status--trialing { background: rgba(20, 102, 255, 0.12); color: var(--primary); }
      .status--inactive { background: rgba(156, 90, 0, 0.12); color: var(--warning); }

      .meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
      }

      .meta-card {
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.78);
      }

      .meta-card__label {
        display: block;
        margin-bottom: 6px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .meta-card__value {
        font-size: 1.15rem;
        font-weight: 700;
      }

      .stack {
        display: grid;
        gap: 12px;
      }

      .hero-visual {
        position: relative;
        min-height: 460px;
        padding: 24px;
        border-radius: var(--radius-xl);
        background:
          radial-gradient(circle at 85% 18%, rgba(183, 235, 227, 0.2), transparent 18%),
          linear-gradient(155deg, var(--surface-dark) 0%, var(--surface-dark-strong) 100%);
        color: white;
        overflow: hidden;
      }

      .hero-visual::after {
        content: "";
        position: absolute;
        inset: auto -8% -22% auto;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        background: rgba(215, 241, 235, 0.12);
        filter: blur(2px);
      }

      .hero-visual__window,
      .showcase-card {
        position: relative;
        z-index: 1;
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(10px);
      }

      .hero-visual__window {
        padding: 18px;
      }

      .window__chrome {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 18px;
        color: rgba(235, 247, 244, 0.84);
        font-size: 0.86rem;
      }

      .window__dots {
        display: inline-flex;
        gap: 6px;
      }

      .window__dots span {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.48);
      }

      .transcript-card {
        display: grid;
        gap: 12px;
      }

      .transcript-line {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.08);
        line-height: 1.55;
      }

      .transcript-line--strong {
        background: rgba(255, 255, 255, 0.14);
        color: white;
        font-weight: 600;
      }

      .transcript-output {
        display: grid;
        gap: 8px;
        padding: 16px;
        border-radius: 22px;
        background: rgba(215, 241, 235, 0.92);
        color: var(--ink);
      }

      .transcript-output p {
        margin: 0;
        line-height: 1.6;
      }

      .hero-visual__cards {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 12px;
      }

      .signal-card,
      .mini-stat,
      .feature-card,
      .workflow-card,
      .plan-card {
        padding: 20px;
      }

      .signal-card {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.1);
        color: white;
      }

      .signal-card p {
        color: rgba(229, 244, 240, 0.78);
      }

      .signal-card strong,
      .mini-stat strong {
        display: block;
        margin-bottom: 8px;
        font-family: var(--font-display);
        font-size: 1.35rem;
        line-height: 1;
        letter-spacing: -0.03em;
      }

      .mini-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        width: 100%;
      }

      .mini-stat {
        background: rgba(255, 255, 255, 0.88);
      }

      .feature-band {
        position: relative;
        overflow: hidden;
        padding: clamp(26px, 4vw, 40px);
        background:
          radial-gradient(circle at 18% 18%, rgba(215, 241, 235, 0.12), transparent 18%),
          linear-gradient(155deg, var(--surface-dark) 0%, #0a514a 100%);
        border-color: rgba(255, 255, 255, 0.08);
        color: white;
      }

      .feature-band::before {
        content: "";
        position: absolute;
        left: -10%;
        right: -10%;
        bottom: -90px;
        height: 170px;
        border-radius: 50%;
        background: linear-gradient(180deg, rgba(215, 241, 235, 0.12), rgba(215, 241, 235, 0.02));
      }

      .feature-band__grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(280px, 0.92fr) minmax(0, 1.08fr);
        gap: 28px;
        align-items: center;
      }

      .showcase-card {
        padding: 20px;
      }

      .showcase-card + .showcase-card {
        margin-top: 14px;
      }

      .showcase-card__label {
        display: inline-flex;
        margin-bottom: 12px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .showcase-card p {
        color: rgba(233, 246, 243, 0.8);
      }

      .showcase-list {
        display: grid;
        gap: 10px;
        margin-top: 12px;
      }

      .showcase-list span {
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255, 255, 255, 0.9);
      }

      .showcase-list span::before,
      .checklist li::before {
        content: "";
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 6px rgba(215, 241, 235, 0.12);
        flex: 0 0 auto;
      }

      .workflow-grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .workflow-card__step {
        display: inline-flex;
        margin-bottom: 14px;
        padding: 6px 10px;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary);
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .feature-card h3,
      .workflow-card h3,
      .plan-card__price,
      .mini-stat h3 {
        font-family: var(--font-display);
        letter-spacing: -0.03em;
      }

      .pricing-block__grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
        gap: 20px;
        align-items: start;
      }

      .plan-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 251, 249, 0.92));
      }

      .plan-card__eyebrow {
        display: inline-flex;
        margin-bottom: 14px;
        padding: 7px 12px;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .plan-card__price {
        margin: 0 0 6px;
        font-size: clamp(2.2rem, 4vw, 3rem);
        line-height: 1;
      }

      .checklist {
        display: grid;
        gap: 12px;
        margin: 18px 0 0;
        padding: 0;
        list-style: none;
      }

      .checklist li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        color: var(--muted);
      }

      .trust-strip {
        display: grid;
        gap: 18px;
      }

      code {
        padding: 2px 6px;
        border-radius: 8px;
        background: rgba(8, 39, 36, 0.08);
      }

      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(14px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      main > * {
        animation: rise 520ms ease both;
      }

      main > *:nth-child(2) { animation-delay: 60ms; }
      main > *:nth-child(3) { animation-delay: 120ms; }
      main > *:nth-child(4) { animation-delay: 180ms; }
      main > *:nth-child(5) { animation-delay: 240ms; }
      main > *:nth-child(6) { animation-delay: 300ms; }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        main > * { animation: none; }
      }

      @media (max-width: 980px) {
        .hero__layout,
        .feature-band__grid,
        .pricing-block__grid,
        .split {
          grid-template-columns: 1fr;
        }

        .workflow-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .cards-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 820px) {
        .shell { width: min(100vw - 20px, 100%); padding-top: 12px; }
        .shell__header {
          align-items: flex-start;
          border-radius: 28px;
        }

        .nav {
          width: 100%;
          justify-content: flex-start;
        }

        .brand__tag { max-width: 34ch; }
        .hero__title,
        .hero--landing .hero__title { max-width: none; }
        .mini-stats,
        .cards-grid,
        .cards-grid--two,
        .split { grid-template-columns: 1fr; }
        .workflow-grid { grid-template-columns: 1fr; }
        .hero-visual__cards { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="shell__header">
        <a class="brand" href="<%= pricing_path %>">
          <span class="brand__name"><%= AppConfig.app_name %></span>
          <span class="brand__tag">Voice-first writing for macOS with unified billing and entitlement</span>
        </a>

        <nav class="nav">
          <div class="nav__links">
            <a class="nav__link" href="<%= pricing_path(anchor: "product") %>">Product</a>
            <a class="nav__link" href="<%= pricing_path(anchor: "workflow") %>">Workflow</a>
            <a class="nav__link" href="<%= pricing_path(anchor: "pricing") %>">Pricing</a>
            <a class="nav__link" href="<%= release_notes_path %>">Release notes</a>
          </div>
          <% if authenticated? %>
            <a class="nav__link" href="<%= account_path %>">Account</a>
            <span class="pill"><%= current_user_email %></span>
            <%= button_to "Sign out", logout_path, method: :delete, class: "button button--secondary" %>
          <% else %>
            <a class="button button--secondary" href="<%= login_path %>">Sign in</a>
          <% end %>
        </nav>
      </header>

      <% if notice.present? || alert.present? || flash.now[:notice].present? || flash.now[:alert].present? %>
        <div class="flash-stack">
          <% [notice, flash.now[:notice]].compact.each do |message| %>
            <div class="flash flash--notice"><%= message %></div>
          <% end %>
          <% [alert, flash.now[:alert]].compact.each do |message| %>
            <div class="flash flash--alert"><%= message %></div>
          <% end %>
        </div>
      <% end %>

      <main>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
