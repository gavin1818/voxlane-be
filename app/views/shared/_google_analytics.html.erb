<% measurement_id = AppConfig.google_analytics_measurement_id %>
<% if AppConfig.google_analytics_enabled? %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ERB::Util.url_encode(measurement_id) %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= j(measurement_id) %>');
  </script>
<% end %>
